#!/data/data/com.termux/files/usr/bin/sh

set -eu

PREFIX_DIR="${PREFIX:-/data/data/com.termux/files/usr}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/btop-rish"
TMP_DIR="${TMPDIR:-$HOME/.tmp}/btop-rish"
RISH_BIN="${RISH_BIN:-}"
REMOTE_BTOP_DIR="/data/local/tmp/btop"
REMOTE_BTOP_BIN="$REMOTE_BTOP_DIR/btop"
REMOTE_STD_CFG="/data/local/tmp/btop-config/btop"
REMOTE_MINI_CFG="/data/local/tmp/btop-mini/btop"
RELEASE_REPO="${BTOP_RELEASE_REPO:-aristocratos/btop}"
RELEASE_TAG="${BTOP_RELEASE_TAG:-latest}"
RELEASE_URL="${BTOP_RELEASE_URL:-}"
LOCAL_BTOP=""

log() { printf '%s\n' "$*"; }
fail() { printf 'setup-btop-rish: %s\n' "$*" >&2; exit 1; }

usage() {
    cat <<'EOF'
usage: setup-btop-rish [--local /path/to/btop]

Installs a Linux btop binary into /data/local/tmp through Shizuku rish and
creates Termux wrapper commands:
  btop-shizuku
  mini-btop-shizuku

Environment overrides:
  RISH_BIN=/path/to/rish
  BTOP_RELEASE_URL=https://...
  BTOP_RELEASE_REPO=aristocratos/btop
  BTOP_RELEASE_TAG=latest
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --local)
            shift
            LOCAL_BTOP="${1:-}"
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            fail "unknown argument: $1"
            ;;
    esac
    shift || true
done

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

resolve_rish() {
    if [ -n "$RISH_BIN" ]; then
        [ -x "$RISH_BIN" ] || fail "RISH_BIN is not executable: $RISH_BIN"
        return 0
    fi

    RISH_BIN="$(command -v rish 2>/dev/null || true)"
    [ -n "$RISH_BIN" ] || fail "missing required command in PATH: rish"
}

rish_exec() {
    "$RISH_BIN" -c "$1"
}

candidate_assets() {
    arch="$(uname -m 2>/dev/null || echo unknown)"
    case "$arch" in
        aarch64|arm64)
            printf '%s\n' \
                btop-aarch64-unknown-linux-musl.tar.gz \
                btop-aarch64-unknown-linux-musl.tbz \
                btop-aarch64-linux-musl.tar.gz \
                btop-aarch64-linux-musl.tbz
            ;;
        x86_64|amd64)
            printf '%s\n' \
                btop-x86_64-unknown-linux-musl.tar.gz \
                btop-x86_64-unknown-linux-musl.tbz \
                btop-x86_64-linux-musl.tar.gz \
                btop-x86_64-linux-musl.tbz
            ;;
        armv7l|armv7|arm)
            printf '%s\n' \
                btop-armv7-unknown-linux-musleabi.tar.gz \
                btop-armv7-unknown-linux-musleabi.tbz \
                btop-armv7-unknown-linux-musleabihf.tbz \
                btop-armv7l-linux-musleabi.tar.gz \
                btop-armv7l-linux-musleabi.tbz
            ;;
        i686|i386)
            printf '%s\n' \
                btop-i686-unknown-linux-musl.tar.gz \
                btop-i686-unknown-linux-musl.tbz \
                btop-i686-linux-musl.tar.gz \
                btop-i686-linux-musl.tbz
            ;;
        *)
            return 1
            ;;
    esac
}

asset_url() {
    asset="$1"
    if [ "$RELEASE_TAG" = "latest" ]; then
        printf 'https://github.com/%s/releases/latest/download/%s\n' "$RELEASE_REPO" "$asset"
    else
        printf 'https://github.com/%s/releases/download/%s/%s\n' "$RELEASE_REPO" "$RELEASE_TAG" "$asset"
    fi
}

extract_archive() {
    archive="$1"
    dest="$2"
    case "$archive" in
        *.tar.gz|*.tgz)
            tar -xzf "$archive" -C "$dest"
            ;;
        *.tbz|*.tbz2|*.tar.bz2)
            tar -xjf "$archive" -C "$dest"
            ;;
        *)
            return 1
            ;;
    esac
}

download_btop() {
    require_cmd curl
    require_cmd tar
    rm -rf "$TMP_DIR"
    mkdir -p "$CACHE_DIR" "$TMP_DIR/extract"

    if [ -n "$RELEASE_URL" ]; then
        archive="$CACHE_DIR/$(basename "${RELEASE_URL%%\?*}")"
        curl -fL --connect-timeout 10 --max-time 180 "$RELEASE_URL" -o "$archive"
        extract_archive "$archive" "$TMP_DIR/extract" || fail "unsupported archive type: $archive"
        found="$(find "$TMP_DIR/extract" -type f -name btop | head -n 1 || true)"
        [ -n "$found" ] || fail "archive did not contain a btop binary"
        chmod 755 "$found"
        printf '%s\n' "$found"
        return 0
    fi

    for asset in $(candidate_assets || true); do
        url="$(asset_url "$asset")"
        archive="$CACHE_DIR/$asset"
        log "Trying $url" >&2
        if ! curl -fL --connect-timeout 10 --max-time 180 "$url" -o "$archive"; then
            continue
        fi
        rm -rf "$TMP_DIR/extract"
        mkdir -p "$TMP_DIR/extract"
        extract_archive "$archive" "$TMP_DIR/extract" || continue
        found="$(find "$TMP_DIR/extract" -type f -name btop | head -n 1 || true)"
        if [ -n "$found" ]; then
            chmod 755 "$found"
            printf '%s\n' "$found"
            return 0
        fi
    done

    return 1
}

write_configs() {
    mkdir -p "$TMP_DIR"
    cat > "$TMP_DIR/btop.conf" <<'CONF'
shown_boxes = "cpu mem proc"
io_mode = False
show_io_stat = False
net_auto = False
net_sync = False
net_iface = ""
show_disks = False
color_theme = "TTY"
theme_background = False
truecolor = True
rounded_corners = True
graph_symbol = "braille"
proc_sorting = "cpu lazy"
proc_tree = False
update_ms = 2000
CONF

    cat > "$TMP_DIR/mini-btop.conf" <<'CONF'
shown_boxes = "cpu proc"
io_mode = False
show_io_stat = False
net_auto = False
net_sync = False
net_iface = ""
show_disks = False
color_theme = "TTY"
theme_background = False
truecolor = True
rounded_corners = True
graph_symbol = "braille"
cpu_single_graph = True
proc_sorting = "cpu lazy"
proc_tree = False
update_ms = 2000
CONF
}

install_remote() {
    src="$1"
    [ -f "$src" ] || fail "btop binary not found: $src"
    rish_exec "set -eu; mkdir -p '$REMOTE_BTOP_DIR' '$REMOTE_STD_CFG' '$REMOTE_MINI_CFG'"
    cat "$src" | rish_exec "set -eu; cat > '$REMOTE_BTOP_BIN'; chmod 755 '$REMOTE_BTOP_BIN'"
    cat "$TMP_DIR/btop.conf" | rish_exec "set -eu; cat > '$REMOTE_STD_CFG/btop.conf'"
    cat "$TMP_DIR/mini-btop.conf" | rish_exec "set -eu; cat > '$REMOTE_MINI_CFG/btop.conf'"
}

install_wrappers() {
    mkdir -p "$PREFIX_DIR/bin"
    cat > "$PREFIX_DIR/bin/btop-shizuku" <<'WRAP'
#!/data/data/com.termux/files/usr/bin/sh
exec rish -c "XDG_CONFIG_HOME=/data/local/tmp/btop-config /data/local/tmp/btop/btop --force-utf"
WRAP
    cat > "$PREFIX_DIR/bin/mini-btop-shizuku" <<'WRAP'
#!/data/data/com.termux/files/usr/bin/sh
exec rish -c "XDG_CONFIG_HOME=/data/local/tmp/btop-mini /data/local/tmp/btop/btop --force-utf"
WRAP
    chmod 755 "$PREFIX_DIR/bin/btop-shizuku" "$PREFIX_DIR/bin/mini-btop-shizuku"
}

main() {
    require_cmd find
    require_cmd launcherctl
    resolve_rish
    rish_exec "echo ready" >/dev/null || fail "rish did not execute successfully; check Shizuku permission"

    if [ -n "$LOCAL_BTOP" ]; then
        src="$LOCAL_BTOP"
    else
        src="$(download_btop)" || fail "could not download a matching btop release; pass --local /path/to/btop"
    fi

    write_configs
    install_remote "$src"
    install_wrappers

    log "btop installed through rish:"
    log "  remote: $REMOTE_BTOP_BIN"
    log "  wrappers: btop-shizuku, mini-btop-shizuku"
}

main "$@"
