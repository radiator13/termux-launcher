#!/data/data/com.termux/files/usr/bin/sh

set -eu

RAW_BASE="${TERMUX_LAUNCHER_RAW_BASE:-https://raw.githubusercontent.com/PickleHik3/termux-launcher/main/docs/en/examples}"
TPM_REPO="${TPM_REPO:-https://github.com/tmux-plugins/tpm}"
PLUGIN_REPO="${TERMUX_LAUNCHER_TMUX_REPO:-https://github.com/PickleHik3/termux-launcher-tmux}"
TPM_DIR="${TPM_DIR:-$HOME/.tmux/plugins/tpm}"
PLUGIN_DIR="${TERMUX_LAUNCHER_TMUX_DIR:-$HOME/.tmux/plugins/termux-launcher-tmux}"
TMUX_CONF="${TMUX_CONF:-$HOME/.tmux.conf}"
BTOP_SETUP="${BTOP_SETUP:-$HOME/setup-btop-rish}"
FISH_CONFIG="${FISH_CONFIG:-$HOME/.config/fish/config.fish}"
OMP_CONFIG="${OMP_CONFIG:-$HOME/.config/ohmyposh/termux-launcher.omp.json}"

log() { printf '%s\n' "$*"; }
warn() { printf 'setup-tmux-btop: %s\n' "$*" >&2; }
fail() { warn "$*"; exit 1; }

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

show_material_colors_help() {
    cat >&2 <<'EOF'

Terminal Material colors are recommended for the tmux theme.

To use wallpaper-derived colors in Termux Launcher:
  1. Long press Terminal.
  2. Open More -> Settings -> Appearance.
  3. Turn on Terminal Material colors.
  4. Return to the terminal and run this script again.

Plain Termux users can continue with the built-in fallback colors.
EOF
}

show_rish_help() {
    cat >&2 <<'EOF'

rish is required for the Shizuku btop helper.

Set it up first:
  1. Install and start Shizuku.
  2. In Shizuku, open Use Shizuku in terminal apps.
  3. Let Shizuku create rish and rish_shizuku.dex.
  4. Put both files in a Termux PATH directory. For example, use
       ~/.local/bin
     only if that directory is already in PATH or you add it to PATH.
  5. Make rish executable if needed:
       chmod +x "$(command -v rish)"
  6. Edit the bottom of rish so it uses:
       RISH_APPLICATION_ID="com.termux"
  7. Run rish once and grant the Shizuku permission prompt.
  8. Run this setup script again.

The full manual walkthrough is in the Termux Launcher Getting Started page.
EOF
}

welcome() {
    cat <<'EOF'
Termux Launcher optional shell, tmux, and btop setup

Before the tmux theme will use wallpaper-derived colors:
  - Open Settings -> Appearance in Termux Launcher.
  - Turn on Terminal Material colors.
  - Start Shizuku for launcher resource widgets such as CPU and RAM.
    In plain Termux without Termux Launcher, the status helper can fall back
    to rish, but that path is less efficient than launcherctl.

Before the Shizuku btop helper can be installed:
  - Put rish in your PATH and grant it Shizuku access.

This script can install Fish, Oh My Posh and their matching configs, install
TPM and the Termux Launcher TPM plugin, and run the rish-backed btop helper.
EOF
}

choose_setup() {
    cat >&2 <<'EOF'

Choose what to set up:
  1) All (Fish + Oh My Posh, tmux, and btop)
  2) tmux only
  3) btop only
  4) Exit
EOF
    printf '> ' >&2
    IFS= read -r choice
    case "$choice" in
        1|all|All|ALL) printf 'all\n' ;;
        2|tmux|TMUX) printf 'tmux\n' ;;
        3|btop|BTOP) printf 'btop\n' ;;
        4|exit|Exit|EXIT|'') printf 'exit\n' ;;
        *) fail "unknown choice: $choice" ;;
    esac
}

install_missing_packages() {
    missing_packages=""

    for item in "$@"; do
        cmd="${item%%:*}"
        package="${item#*:}"
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing_packages="$missing_packages $package"
        fi
    done

    [ -n "$missing_packages" ] || return 0
    require_cmd pkg
    log
    log "Installing missing Termux packages:$missing_packages"
    # pkg fronts apt and pacman Termux installs.
    pkg install -y $missing_packages
}

install_if_missing() {
    source_url="$1"
    destination="$2"
    label="$3"

    if [ -e "$destination" ]; then
        log "Keeping existing $label: $destination"
        return 0
    fi

    mkdir -p "$(dirname "$destination")"
    curl -fsSL "$source_url" -o "$destination"
    log "Installed $label: $destination"
}

install_shell_setup() {
    log
    log "Setting up Fish and Oh My Posh..."
    install_missing_packages fish:fish oh-my-posh:oh-my-posh curl:curl eza:eza zoxide:zoxide
    require_cmd curl

    install_if_missing "$RAW_BASE/config.fish" "$FISH_CONFIG" "Fish config"
    install_if_missing "$RAW_BASE/termux-launcher.omp.json" "$OMP_CONFIG" "Oh My Posh theme"

    log "Shell setup complete. Start it with: exec fish"
}

material_colors_ready() {
    [ -s "$HOME/.termux/material-colors.sh" ] ||
        [ -s "$HOME/.termux/material-colors.properties" ]
}

rish_available() {
    if [ -n "${RISH_BIN:-}" ]; then
        [ -x "$RISH_BIN" ]
        return $?
    fi
    command -v rish >/dev/null 2>&1
}

ensure_tmux_conf_line() {
    needle="$1"
    line="$2"

    touch "$TMUX_CONF"
    if ! grep -Fq "$needle" "$TMUX_CONF"; then
        {
            printf '\n'
            printf '%s\n' "$line"
        } >> "$TMUX_CONF"
    fi
}

install_tmux_plugin() {
    log
    log "Setting up tmux theme and TPM..."
    if ! material_colors_ready; then
        warn "Terminal Material colors export was not found."
        show_material_colors_help
        log "Continuing with built-in fallback colors."
    fi

    install_missing_packages tmux:tmux curl:curl jq:jq git:git

    if [ ! -d "$TPM_DIR/.git" ]; then
        mkdir -p "$(dirname "$TPM_DIR")"
        git clone "$TPM_REPO" "$TPM_DIR"
    fi

    if [ ! -d "$PLUGIN_DIR/.git" ]; then
        mkdir -p "$(dirname "$PLUGIN_DIR")"
        git clone "$PLUGIN_REPO" "$PLUGIN_DIR"
    fi

    ensure_tmux_conf_line "PickleHik3/termux-launcher-tmux" \
        "set -g @plugin 'PickleHik3/termux-launcher-tmux'"
    ensure_tmux_conf_line "plugins/tpm/tpm" \
        "run '$TPM_DIR/tpm'"

    log "tmux theme setup complete."
    log "  TPM: $TPM_DIR"
    log "  Plugin: $PLUGIN_DIR"
    log "  Config: $TMUX_CONF"

    if command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
        tmux source-file "$TMUX_CONF" || warn "tmux could not reload $TMUX_CONF"
    fi
}

install_btop_helper() {
    log
    log "Setting up btop through Shizuku rish..."

    if ! rish_available; then
        warn "rish is not available in PATH and RISH_BIN is not executable."
        show_rish_help
        return 1
    fi

    install_missing_packages curl:curl tar:tar
    require_cmd curl

    curl -fsSL "$RAW_BASE/setup-btop-rish" -o "$BTOP_SETUP"
    chmod 700 "$BTOP_SETUP"
    "$BTOP_SETUP"
}

