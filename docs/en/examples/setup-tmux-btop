print_guide() {
    cat <<'EOF'

Next steps
  - Start tmux with: tmux
  - In the Termux Launcher tmux plugin, Alt+e opens the keybind reference.
  - After editing ~/.termux/termux.properties, run: termux-reload-settings
  - Also run termux-reload-settings if terminal UI changes feel stale or stuttery.
  - btop wrappers are named btop-shizuku and mini-btop-shizuku.
EOF
    print_extra_keys
}

main() {
    welcome
    selection="$(choose_setup)"
    case "$selection" in
        all)
            install_shell_setup
            install_tmux_plugin
            install_btop_helper
            ;;
        tmux)
            install_tmux_plugin
            ;;
        btop)
            install_btop_helper
            ;;
        exit)
            exit 0
            ;;
    esac
    print_guide
}

main "$@"
