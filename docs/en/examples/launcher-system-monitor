#!/data/data/com.termux/files/usr/bin/sh

set -u

CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-system-monitor.json"
RISH_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-system-monitor-rish"
RISH_CPU_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-system-monitor-rish-cpu"
MAX_AGE="${LAUNCHER_MONITOR_MAX_AGE:-4}"
FORMAT="${1:-compact}"

now() {
    date +%s
}

mtime() {
    stat -c %Y "$1" 2>/dev/null || echo 0
}

cache_is_fresh() {
    cache_file="$1"
    [ -r "$cache_file" ] || return 1
    age=$(( $(now) - $(mtime "$cache_file") ))
    [ "$age" -ge 0 ] && [ "$age" -le "$MAX_AGE" ]
}

refresh_launcher_cache() {
    command -v launcherctl >/dev/null 2>&1 || return 1
    command -v jq >/dev/null 2>&1 || return 1

    tmp="${CACHE}.$$"
    if launcherctl resources > "$tmp" 2>/dev/null && jq -e '.ok == true' "$tmp" >/dev/null 2>&1; then
        mv "$tmp" "$CACHE"
        return 0
    fi
    rm -f "$tmp"
    return 1
}

ensure_launcher_cache() {
    cache_is_fresh "$CACHE" || refresh_launcher_cache
}

round_percent() {
    awk -v percent="${1:-0}" 'BEGIN {
        p = int(percent + 0.5)
        if (p < 0) p = 0
        if (p > 100) p = 100
        print p
    }'
}

percent_from_delta() {
    total_delta="$1"
    idle_delta="$2"
    awk -v total_delta="$total_delta" -v idle_delta="$idle_delta" '
        BEGIN {
            if (total_delta <= 0) exit 1
            percent = 100 * (1 - (idle_delta / total_delta))
            if (percent < 0) percent = 0
            if (percent > 100) percent = 100
                printf "%.0f\n", percent
            }'
}

launcher_cpu_percent() {
    ensure_launcher_cache || [ -r "$CACHE" ] || return 1
    raw="$(jq -r '.cpuPercent // empty' "$CACHE" 2>/dev/null || true)"
    [ -n "$raw" ] || return 1
    round_percent "$raw"
}

launcher_ram_percent() {
    ensure_launcher_cache || [ -r "$CACHE" ] || return 1
    jq -r '
      def pct($used; $total):
        if ($total // 0) > 0 then (($used / $total) * 100 | round) else empty end;
      pct(.memUsedBytes; .memTotalBytes)
    ' "$CACHE" 2>/dev/null
}

launcher_mem_available_gb() {
    ensure_launcher_cache || [ -r "$CACHE" ] || return 1
    jq -r '
      if (.memAvailableBytes // 0) > 0 then
        (.memAvailableBytes / 1073741824 | floor)
      else empty end
    ' "$CACHE" 2>/dev/null
}

resolve_rish() {
    if [ -n "${RISH_BIN:-}" ] && [ -x "$RISH_BIN" ]; then
        printf '%s\n' "$RISH_BIN"
        return 0
    fi

    path_rish="$(command -v rish 2>/dev/null || true)"
    for candidate in "$path_rish" "$HOME/.rish/rish" "$HOME/.local/bin/rish"; do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        printf '%s\n' "$candidate"
        return 0
    done
    return 1
}

rish_shell() {
    rish_bin="$1"
    command_text="$2"
    if command -v timeout >/dev/null 2>&1; then
        timeout 3 "$rish_bin" -c "$command_text"
    else
        "$rish_bin" -c "$command_text"
    fi
}

read_rish_snapshot() {
    rish_bin="$(resolve_rish)" || return 1
    rish_shell "$rish_bin" 'cat /proc/stat 2>/dev/null; cat /proc/meminfo 2>/dev/null' 2>/dev/null |
        awk '
            /^cpu / {
                total = 0
                for (i = 2; i <= NF; i++) total += $i
                idle = $5 + $6
            }
            /^MemTotal:/ { mem_total = $2 }
            /^MemAvailable:/ { mem_available = $2 }
            END {
                if (total > 0 || mem_total > 0) {
                    print total + 0, idle + 0, mem_total + 0, mem_available + 0
                }
            }'
}

refresh_rish_cache() {
    snapshot="$(read_rish_snapshot)" || return 1
    [ -n "$snapshot" ] || return 1
    set -- $snapshot
    total="${1:-0}"
    idle="${2:-0}"
    mem_total_kb="${3:-0}"
    mem_available_kb="${4:-0}"

    cpu_percent=""
    if [ "$total" -gt 0 ] 2>/dev/null; then
        if [ -r "$RISH_CPU_CACHE" ]; then
            set -- $(cat "$RISH_CPU_CACHE" 2>/dev/null || true)
            prev_total="${1:-}"
            prev_idle="${2:-}"
            if [ -n "$prev_total" ] && [ -n "$prev_idle" ] &&
                [ "$total" -gt "$prev_total" ] 2>/dev/null; then
                cpu_percent="$(percent_from_delta "$((total - prev_total))" "$((idle - prev_idle))" 2>/dev/null || true)"
            fi
        fi

        if [ -z "$cpu_percent" ]; then
            sleep 0.2
            snapshot2="$(read_rish_snapshot)" || snapshot2=""
            if [ -n "$snapshot2" ]; then
                set -- $snapshot2
                total2="${1:-0}"
                idle2="${2:-0}"
                if [ "$total2" -gt "$total" ] 2>/dev/null; then
                    cpu_percent="$(percent_from_delta "$((total2 - total))" "$((idle2 - idle))" 2>/dev/null || true)"
                    total="$total2"
                    idle="$idle2"
                fi
            fi
        fi
        printf '%s %s\n' "$total" "$idle" > "$RISH_CPU_CACHE"
    fi

    ram_percent=""
    mem_used_bytes=""
    mem_total_bytes=""
    mem_available_bytes=""
    if [ "$mem_total_kb" -gt 0 ] && [ "$mem_available_kb" -gt 0 ] 2>/dev/null; then
        mem_used_kb=$((mem_total_kb - mem_available_kb))
        mem_total_bytes=$((mem_total_kb * 1024))
        mem_available_bytes=$((mem_available_kb * 1024))
        mem_used_bytes=$((mem_used_kb * 1024))
        ram_percent="$(awk -v used="$mem_used_kb" -v total="$mem_total_kb" 'BEGIN {
            if (total <= 0) exit 1
            printf "%.0f\n", (used / total) * 100
        }' 2>/dev/null || true)"
    fi

    tmp="${RISH_CACHE}.$$"
    {
        [ -n "$cpu_percent" ] && printf 'cpu=%s\n' "$cpu_percent"
        [ -n "$ram_percent" ] && printf 'ram=%s\n' "$ram_percent"
        [ -n "$mem_total_bytes" ] && printf 'mem_total_bytes=%s\n' "$mem_total_bytes"
        [ -n "$mem_available_bytes" ] && printf 'mem_available_bytes=%s\n' "$mem_available_bytes"
        [ -n "$mem_used_bytes" ] && printf 'mem_used_bytes=%s\n' "$mem_used_bytes"
    } > "$tmp"

    if [ -s "$tmp" ]; then
        mv "$tmp" "$RISH_CACHE"
        return 0
    fi
    rm -f "$tmp"
    return 1
}

ensure_rish_cache() {
    cache_is_fresh "$RISH_CACHE" || refresh_rish_cache
}

rish_value() {
    ensure_rish_cache || [ -r "$RISH_CACHE" ] || return 1
    awk -F= -v key="$1" '$1 == key { print $2; exit }' "$RISH_CACHE" 2>/dev/null
}

rish_cpu_percent() {
    value="$(rish_value cpu)"
    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

rish_ram_percent() {
    value="$(rish_value ram)"
    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

rish_mem_available_gb() {
    value="$(rish_value mem_available_bytes)"
    [ -n "$value" ] || return 1
    awk -v bytes="$value" 'BEGIN {
        if (bytes <= 0) exit 1
        printf "%d\n", bytes / 1073741824
    }'
}

cpu_percent() {
    launcher_cpu_percent 2>/dev/null || rish_cpu_percent 2>/dev/null
}

ram_percent() {
    launcher_ram_percent 2>/dev/null || rish_ram_percent 2>/dev/null
}

mem_available_gb() {
    launcher_mem_available_gb 2>/dev/null || rish_mem_available_gb 2>/dev/null
}

format_percent() {
    awk -v percent="${1:-0}" '
        BEGIN {
            p = int(percent + 0.5)
            if (p < 0) p = 0
            if (p > 100) p = 100
            if (p < 100) printf "%02d%%", p
            else printf "100%%"
        }'
}

cpu_segment() {
    percent="$(cpu_percent 2>/dev/null || true)"
    [ -n "$percent" ] || {
        printf ' --'
        return
    }
    printf ' %s' "$(format_percent "$percent")"
}

ram_segment() {
    percent="$(ram_percent 2>/dev/null || true)"
    [ -n "$percent" ] || {
        printf ' --'
        return
    }
    printf ' %s' "$(format_percent "$percent")"
}

detailed_segment() {
    ram="$(ram_percent 2>/dev/null || true)"
    free_gb="$(mem_available_gb 2>/dev/null || true)"
    cpu_segment
    printf '  '
    if [ -n "$ram" ]; then
        printf ' %s' "$(format_percent "$ram")"
        [ -n "$free_gb" ] && printf ' %sG free' "$free_gb"
    else
        printf ' --'
    fi
}

json_output() {
    if ensure_launcher_cache && [ -r "$CACHE" ]; then
        cat "$CACHE"
        return 0
    fi

    ensure_rish_cache || return 1
    cpu="$(rish_value cpu 2>/dev/null || true)"
    ram="$(rish_value ram 2>/dev/null || true)"
    mem_total="$(rish_value mem_total_bytes 2>/dev/null || true)"
    mem_available="$(rish_value mem_available_bytes 2>/dev/null || true)"
    mem_used="$(rish_value mem_used_bytes 2>/dev/null || true)"
    printf '{"ok":true,"source":"rish"'
    [ -n "$cpu" ] && printf ',"cpuPercent":%s' "$cpu"
    [ -n "$ram" ] && printf ',"memPercent":%s' "$ram"
    [ -n "$mem_total" ] && printf ',"memTotalBytes":%s' "$mem_total"
    [ -n "$mem_available" ] && printf ',"memAvailableBytes":%s' "$mem_available"
    [ -n "$mem_used" ] && printf ',"memUsedBytes":%s' "$mem_used"
    printf '}\n'
}

if [ "$FORMAT" = "cpu" ]; then
    cpu_segment
    exit 0
fi

if [ "$FORMAT" = "ram" ]; then
    ram_segment
    exit 0
fi

case "$FORMAT" in
    json)
        json_output || printf '{"ok":false}\n'
        ;;
    compact|'')
        cpu_segment
        printf ' '
        ram_segment
        ;;
    detailed)
        detailed_segment
        ;;
    *)
        printf 'usage: launcher-system-monitor [compact|detailed|json|cpu|ram]\n' >&2
        exit 2
        ;;
esac
