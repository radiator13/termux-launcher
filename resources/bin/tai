#!/data/data/com.termux/files/usr/bin/sh
set -eu

print_help() {
  cat <<'EOF'
TAI / Termux AI - local multi-backend model host

Usage:
  tai --json <command>
  tai status
  tai runtime
  tai models
  tai import <path> [model-id]
  tai download <model-id> <https-url> --accept-terms
  tai downloads
  tai download-cancel <model-id>
  tai delete <model-id>
  tai load [model] [--auto|--cpu|--gpu]
  tai unload
  tai keep-warm [model] [--minutes N] [--auto|--cpu|--gpu]
  tai cancel
  tai doctor

TAI is authenticated through ~/.launcherctl and runs in the Android app process.
LiteRT-LM, MLC OpenCL, and llama.cpp run in the Android app process when supported by the installed APK.
Auto honors model compatibility profiles and uses backend-specific GPU-first behavior with CPU fallback where available.
Use OpenAI-compatible clients against /v1/models, /v1/chat/completions, and /v1/completions.
Use tai --json <command> for raw API JSON.
EOF
}

LAUNCHERCTL_DIR="$HOME/.launcherctl"
TOKEN_FILE="$LAUNCHERCTL_DIR/token"
ENDPOINT_FILE="$LAUNCHERCTL_DIR/endpoint"
if [ ! -r "$TOKEN_FILE" ] || [ ! -r "$ENDPOINT_FILE" ]; then
  echo "tai: missing $TOKEN_FILE or $ENDPOINT_FILE; start Termux Launcher first" >&2
  exit 1
fi

TOKEN=$(cat "$TOKEN_FILE")
BASE=$(cat "$ENDPOINT_FILE")
CURL_COMMON="--fail-with-body -sS --connect-timeout 2 --max-time 180"

json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }
post_json() {
  path="$1"
  data="$2"
  if [ "$OUTPUT_MODE" = "text" ]; then
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" -H "X-TAI-Output: text" --data "$data" "$BASE$path"
  else
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" --data "$data" "$BASE$path"
  fi
}
get_json() {
  path="$1"
  if [ "$OUTPUT_MODE" = "text" ]; then
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" -H "X-TAI-Output: text" "$BASE$path"
  else
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE$path"
  fi
}

OUTPUT_MODE=text
case "${1:-}" in
  --json|-j)
    OUTPUT_MODE=json
    shift || true
    ;;
esac
cmd="${1:-status}"
shift || true

case "$cmd" in
  -h|--help|help)
    print_help
    ;;
  status)
    get_json /v1/ai/status
    ;;
  runtime)
    get_json /v1/ai/runtime
    ;;
  models)
    get_json /v1/ai/models
    ;;
  import)
    [ "$#" -gt 0 ] || { echo "usage: tai import <path> [model-id]" >&2; exit 2; }
    path=$(json_escape "$1")
    model="${2:-}"
    if [ -n "$model" ]; then
      model=$(json_escape "$model")
      post_json /v1/ai/models/import "{\"path\":\"$path\",\"modelId\":\"$model\"}"
    else
      post_json /v1/ai/models/import "{\"path\":\"$path\"}"
    fi
    ;;
  download)
    [ "$#" -ge 3 ] || { echo "usage: tai download <model-id> <https-url> --accept-terms" >&2; exit 2; }
    model=$(json_escape "$1")
    url=$(json_escape "$2")
    [ "${3:-}" = "--accept-terms" ] || { echo "tai download: pass --accept-terms after reviewing the provider license/terms" >&2; exit 2; }
    post_json /v1/ai/models/download "{\"modelId\":\"$model\",\"url\":\"$url\",\"acceptedTerms\":true}"
    ;;
  downloads)
    get_json /v1/ai/models/downloads
    ;;
  download-cancel)
    [ "$#" -gt 0 ] || { echo "usage: tai download-cancel <model-id>" >&2; exit 2; }
    model=$(json_escape "$1")
    post_json /v1/ai/models/downloads/cancel "{\"modelId\":\"$model\"}"
    ;;
  delete)
    [ "$#" -gt 0 ] || { echo "usage: tai delete <model-id>" >&2; exit 2; }
    model=$(json_escape "$1")
    post_json /v1/ai/models/delete "{\"modelId\":\"$model\"}"
    ;;
  load)
    model=""
    accelerator=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --auto) accelerator=auto ;;
        --cpu) accelerator=cpu ;;
        --gpu) accelerator=gpu ;;
        --*) echo "usage: tai load [model] [--auto|--cpu|--gpu]" >&2; exit 2 ;;
        *) [ -z "$model" ] || { echo "usage: tai load [model] [--auto|--cpu|--gpu]" >&2; exit 2; }; model="$1" ;;
      esac
      shift
    done
    accel_json=""
    if [ -n "$accelerator" ]; then
      accel_json=",\"accelerator\":\"$accelerator\""
    fi
    if [ -n "$model" ]; then
      model_escaped=$(json_escape "$model")
      post_json /v1/ai/runtime/load "{\"model\":\"$model_escaped\"$accel_json}"
    elif [ -n "$accelerator" ]; then
      post_json /v1/ai/runtime/load "{\"accelerator\":\"$accelerator\"}"
    else
      post_json /v1/ai/runtime/load '{}'
    fi
    ;;
  unload)
    post_json /v1/ai/runtime/unload '{}'
    ;;
  keep-warm)
    model=""
    minutes=""
    accelerator=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --minutes)
          shift
          [ "$#" -gt 0 ] || { echo "usage: tai keep-warm [model] [--minutes N] [--auto|--cpu|--gpu]" >&2; exit 2; }
          minutes="$1"
          ;;
        --auto) accelerator=auto ;;
        --cpu) accelerator=cpu ;;
        --gpu) accelerator=gpu ;;
        --*) echo "usage: tai keep-warm [model] [--minutes N] [--auto|--cpu|--gpu]" >&2; exit 2 ;;
        *) [ -z "$model" ] || { echo "usage: tai keep-warm [model] [--minutes N] [--auto|--cpu|--gpu]" >&2; exit 2; }; model="$1" ;;
      esac
      shift
    done
    body="{}"
    sep=""
    if [ -n "$model" ]; then
      model_escaped=$(json_escape "$model")
      body="{\"model\":\"$model_escaped\""
      sep=","
    fi
    if [ -n "$minutes" ]; then
      [ "$body" = "{}" ] && { body="{"; sep=""; }
      body="$body$sep\"minutes\":$minutes"
      sep=","
    fi
    if [ -n "$accelerator" ]; then
      [ "$body" = "{}" ] && { body="{"; sep=""; }
      body="$body$sep\"accelerator\":\"$accelerator\""
      sep=","
    fi
    [ "$body" = "{}" ] || body="$body}"
    post_json /v1/ai/runtime/keep-warm "$body"
    ;;
  cancel)
    post_json /v1/ai/runtime/cancel '{}'
    ;;
  doctor)
    get_json /v1/ai/runtime
    printf '\n'
    get_json /v1/status
    ;;
  *)
    echo "tai: unknown command: $cmd" >&2
    print_help >&2
    exit 2
    ;;
esac
