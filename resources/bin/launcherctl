#!/data/data/com.termux/files/usr/bin/sh
set -eu

print_help() {
  cat <<'EOF'
LauncherCtl CLI - local API client for Termux:Launcher Shizuku integration

Usage:
  launcherctl [command] [args]
  launcherctl help [command]

Commands:
  status                    Get backend/API status.
  apps                      List launchable app activities.
  launch <query>            Launch an app by label, package, or activity.
  resources                 Get system resource snapshot.
  media                     Get now-playing media info.
  art                       Get current media artwork metadata.
  notifications             Get active notifications snapshot.
  restart                   Restart the launcher through authenticated API.
  update-scripts            Refresh Termux Launcher shell helper scripts.
  tty-doctor                Validate local rish setup and print fixes.
  token rotate              Rotate LauncherCtl API auth token.

Examples:
  launcherctl status
  launcherctl apps
  launcherctl launch whatsapp
  launcherctl update-scripts
  launcherctl restart
  launcherctl tty-doctor

Config files:
  ~/.launcherctl/endpoint   Base URL (for example http://127.0.0.1:40851)
  ~/.launcherctl/token      Bearer token used by this client
EOF
}

print_update_scripts_help() {
  cat <<'EOF'
Usage:
  launcherctl update-scripts

Description:
  Refreshes Termux Launcher shell helper scripts without rerunning Getting Started.
  Existing files are backed up before replacement.

Updated files:
  ~/.local/bin/launcher-system-monitor
  ~/.local/bin/launcher-weather-widget
  ~/.local/bin/kew-tmux-status
  ~/.local/bin/kew-now-playing
  ~/setup-btop-rish
  ~/setup-tmux-btop
  ~/.tmux/material-theme.tmux

Environment:
  TERMUX_LAUNCHER_RAW_BASE  Override examples raw URL.
  TERMUX_LAUNCHER_RAW_ROOT  Override repository raw URL.

Notes:
  - ~/.tmux.conf is not overwritten.
  - rish-backed status fallback is supported, but launcherctl resources is more efficient.
EOF
}

print_tty_doctor_help() {
  cat <<'EOF'
Usage:
  launcherctl tty-doctor

Description:
  Checks ~/.rish/rish setup and prints exact remediation commands.
EOF
}

update_scripts() {
  case "${1:-}" in
    -h|--help|help)
      print_update_scripts_help
      return 0
      ;;
    "")
      ;;
    *)
      echo "usage: launcherctl update-scripts" >&2
      return 2
      ;;
  esac

  command -v curl >/dev/null 2>&1 || {
    echo "launcherctl update-scripts: missing required command: curl" >&2
    echo "install it with: pkg install curl" >&2
    return 1
  }

  raw_root="${TERMUX_LAUNCHER_RAW_ROOT:-https://raw.githubusercontent.com/PickleHik3/termux-launcher/main}"
  raw_base="${TERMUX_LAUNCHER_RAW_BASE:-$raw_root/docs/en/examples}"
  stamp="$(date +%Y%m%d-%H%M%S 2>/dev/null || date +%s)"
  tmp_dir="${TMPDIR:-$HOME/.tmp}/launcherctl-update-scripts.$$"
  mkdir -p "$tmp_dir" || return 1
  trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

  update_one() {
    url="$1"
    dest="$2"
    mode="$3"
    syntax="${4:-sh}"
    tmp="$tmp_dir/$(basename "$dest")"

    printf 'Fetching %s\n' "$url"
    if ! curl -fsSL "$url" -o "$tmp"; then
      echo "launcherctl update-scripts: download failed: $url" >&2
      return 1
    fi

    case "$syntax" in
      sh)
        sh -n "$tmp" || {
          echo "launcherctl update-scripts: shell syntax check failed: $url" >&2
          return 1
        }
        ;;
      bash)
        if command -v bash >/dev/null 2>&1; then
          bash -n "$tmp" || {
            echo "launcherctl update-scripts: bash syntax check failed: $url" >&2
            return 1
          }
        fi
        ;;
      none)
        ;;
    esac

    mkdir -p "$(dirname "$dest")" || return 1
    if [ -e "$dest" ]; then
      cp -p "$dest" "$dest.backup.$stamp" || return 1
    fi
    mv "$tmp" "$dest" || return 1
    chmod "$mode" "$dest" || return 1
    printf 'Updated %s\n' "$dest"
  }

  update_one "$raw_base/launcher-system-monitor" "$HOME/.local/bin/launcher-system-monitor" 700 sh
  update_one "$raw_base/launcher-weather-widget" "$HOME/.local/bin/launcher-weather-widget" 700 sh
  update_one "$raw_base/kew-tmux-status" "$HOME/.local/bin/kew-tmux-status" 700 sh
  update_one "$raw_root/resources/scripts/statusbar/kew-now-playing" "$HOME/.local/bin/kew-now-playing" 700 bash
  update_one "$raw_base/setup-btop-rish" "$HOME/setup-btop-rish" 700 sh
  update_one "$raw_base/setup-tmux-btop" "$HOME/setup-tmux-btop" 700 sh
  update_one "$raw_base/material-theme.tmux" "$HOME/.tmux/material-theme.tmux" 700 sh

  cat <<'EOF'
Shell helper scripts are up to date.
Note: ~/.tmux.conf was not changed. Reload tmux if it is already running:
  tmux source-file ~/.tmux.conf
EOF
}

cmd="${1:-status}"

case "$cmd" in
  -h|--help|help)
    sub="${2:-}"
    case "$sub" in
      ""|all)
        print_help
        ;;
      tty-doctor)
        print_tty_doctor_help
        ;;
      update-scripts)
        print_update_scripts_help
        ;;
      *)
        echo "launcherctl: unknown help topic: $sub" >&2
        print_help >&2
        exit 2
        ;;
    esac
    exit 0
    ;;
  update-scripts)
    shift || true
    update_scripts "$@"
    exit $?
    ;;
esac

LAUNCHERCTL_DIR="$HOME/.launcherctl"
TOKEN_FILE="$LAUNCHERCTL_DIR/token"
ENDPOINT_FILE="$LAUNCHERCTL_DIR/endpoint"
if [ ! -r "$TOKEN_FILE" ] || [ ! -r "$ENDPOINT_FILE" ]; then
  echo "launcherctl: missing $TOKEN_FILE or $ENDPOINT_FILE" >&2
  echo "run: launcherctl --help" >&2
  exit 1
fi

TOKEN=$(cat "$TOKEN_FILE")
BASE=$(cat "$ENDPOINT_FILE")
CURL_COMMON="-fsS --connect-timeout 2 --max-time 10"
shift || true

json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }
RISH_DIR="$HOME/.rish"
RISH_BIN="$RISH_DIR/rish"
RISH_DEX="$RISH_DIR/rish_shizuku.dex"

sdk_int() {
  getprop ro.build.version.sdk 2>/dev/null || echo 0
}

tty_doctor() {
  ok=1
  echo "LauncherCtl tty-doctor"
  echo "  rish dir: $RISH_DIR"
  if [ -x "$RISH_BIN" ]; then
    echo "  rish: ok ($RISH_BIN)"
  else
    echo "  rish: missing or not executable ($RISH_BIN)"
    ok=0
  fi
  if [ -f "$RISH_DEX" ]; then
    echo "  dex: ok ($RISH_DEX)"
  else
    echo "  dex: missing ($RISH_DEX)"
    ok=0
  fi
  sdk="$(sdk_int)"
  if [ "$sdk" -ge 34 ] && [ -f "$RISH_DEX" ] && [ -w "$RISH_DEX" ]; then
    echo "  dex perms: not compatible on Android 14+ (dex is writable)"
    ok=0
  fi
  if [ "$ok" -eq 1 ]; then
    echo "  status: healthy"
    return 0
  fi
  cat <<'EOF'

Suggested fix commands:
  mkdir -p ~/.rish
  cp ~/files/.rish/rish ~/.rish/
  cp ~/files/.rish/rish_shizuku.dex ~/.rish/
  chmod 700 ~/.rish/rish
  chmod 400 ~/.rish/rish_shizuku.dex

Then run:
  launcherctl tty-doctor
EOF
  return 1
}

case "$cmd" in
  status)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/status"
    ;;
  apps)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/apps"
    ;;
  launch)
    [ "$#" -gt 0 ] || { echo "usage: launcherctl launch <app name or package>" >&2; exit 2; }
    CMD_ESCAPED=$(json_escape "$*")
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
      --data "{\"query\":\"$CMD_ESCAPED\"}" "$BASE/v1/apps/launch"
    ;;
  resources)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/system/resources"
    ;;
  media)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/media/now-playing"
    ;;
  art)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/media/art"
    ;;
  notifications)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/notifications"
    ;;
  restart)
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/app/restart"
    ;;
  update-scripts)
    update_scripts "$@"
    ;;
  tty-doctor)
    tty_doctor
    ;;
  token)
    sub="${1:-}"; shift || true
    [ "$sub" = "rotate" ] || { echo "usage: launcherctl token rotate" >&2; exit 2; }
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/auth/rotate"
    ;;
  *)
    echo "launcherctl: unknown command: $cmd" >&2
    echo "run: launcherctl --help" >&2
    exit 2
    ;;
esac
