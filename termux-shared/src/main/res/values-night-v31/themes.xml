<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
     https://material.io/develop/android/theming/dark
    -->

    <!--
     BaseActivity DayNight DarkActionBar theme.
     https://github.com/material-components/material-components-android/blob/1.4.0/lib/java/com/google/android/material/theme/res/values/themes.xml#L27
    -->
    <style name="Theme.BaseActivity.DayNight.DarkActionBar" parent="Theme.Material3.DynamicColors.Dark">
        <item name="termuxColorPrimary">@color/termux_primary</item>
        <item name="termuxColorOnPrimary">@color/termux_on_primary</item>
        <item name="termuxColorSecondary">@color/termux_secondary</item>
        <item name="termuxColorOnSecondary">@color/termux_on_secondary</item>
        <item name="termuxColorSurfaceBase">@color/termux_surface_base</item>
        <item name="termuxColorSurfacePanel">@color/termux_surface_panel</item>
        <item name="termuxColorSurfacePanelHigh">@color/termux_surface_panel_high</item>
        <item name="termuxColorSurfacePanelHighest">@color/termux_surface_panel_highest</item>
        <item name="termuxColorOnSurface">@color/termux_on_surface</item>
        <item name="termuxColorOnSurfaceVariant">@color/termux_on_surface_variant</item>
        <item name="termuxColorOutlineVariant">@color/termux_outline_variant</item>
        <item name="termuxColorAccentContainer">@color/termux_accent_container</item>
        <item name="termuxColorOnAccentContainer">@color/termux_on_accent_container</item>
        <item name="termuxColorError">@color/termux_error</item>
        <item name="termuxColorErrorContainer">@color/termux_error_container</item>
        <item name="termuxColorOnErrorContainer">@color/termux_on_error_container</item>
        <item name="termuxColorScrollbar">@color/termux_scrollbar</item>
    </style>

    <!-- BaseActivity DayNight NoActionBar theme. -->
    <style name="Theme.BaseActivity.DayNight.NoActionBar" parent="Theme.Material3.DynamicColors.Dark">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>





    <!--
      BaseDialog DayNight theme.
      https://github.com/material-components/material-components-android/blob/1.4.0/lib/java/com/google/android/material/dialog/res/values/themes.xml#L70
     -->
    <style name="ThemeOverlay.BaseDialog.DayNight" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">?attr/termuxColorPrimary</item>
        <item name="colorOnPrimary">?attr/termuxColorOnPrimary</item>
        <item name="colorSurface">?attr/termuxColorSurfacePanelHigh</item>
        <item name="colorOnSurface">?attr/termuxColorOnSurface</item>
        <item name="colorOutlineVariant">?attr/termuxColorOutlineVariant</item>

        <!-- Dialog title panel style. -->
        <item name="materialAlertDialogTitlePanelStyle">@style/BaseDialog.Title.Panel</item>

        <!-- Dialog message text style. -->
        <item name="materialAlertDialogBodyTextStyle">@style/BaseDialog.Message.Text.Dark</item>
    </style>

</resources>
