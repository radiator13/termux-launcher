<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:paddingStart="24dp"
    android:paddingTop="6dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/tai_action_stop"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="5dp"
        android:layout_weight="1"
        android:background="@drawable/settings_action_card_primary_background"
        android:contentDescription="@string/termux_ai_runtime_stop_title"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/termux_ai_runtime_stop_title"
            android:textColor="?attr/termuxColorOnAccentContainer"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.8"
            android:text="@string/termux_ai_runtime_stop_summary"
            android:textColor="?attr/termuxColorOnAccentContainer"
            android:textSize="11.5sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tai_action_unload"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:layout_weight="1"
        android:background="@drawable/settings_card_background"
        android:contentDescription="@string/termux_ai_runtime_unload_title"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/termux_ai_runtime_unload_title"
            android:textColor="?attr/termuxColorOnSurface"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/termux_ai_action_unload_sub"
            android:textColor="?attr/termuxColorOnSurfaceVariant"
            android:textSize="11.5sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tai_action_logs"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="5dp"
        android:layout_weight="1"
        android:background="@drawable/settings_card_background"
        android:contentDescription="@string/termux_ai_runtime_logs_title"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/termux_ai_runtime_logs_title"
            android:textColor="?attr/termuxColorOnSurface"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/termux_ai_runtime_logs_summary"
            android:textColor="?attr/termuxColorOnSurfaceVariant"
            android:textSize="11.5sp" />
    </LinearLayout>
</LinearLayout>
