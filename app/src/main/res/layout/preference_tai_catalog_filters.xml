<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="5dp"
    android:paddingEnd="24dp"
    android:paddingBottom="5dp">

    <FrameLayout
        android:id="@+id/tai_backend_segment"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/settings_card_background"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <View
            android:id="@+id/tai_backend_segment_indicator"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:background="@drawable/settings_pill_background"
            android:backgroundTint="?attr/termuxColorPrimaryContainer" />

        <LinearLayout
            android:id="@+id/tai_backend_segment_labels"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tai_catalog_filter_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/termux_ai_catalog_backend_all"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tai_catalog_filter_litert"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/termux_ai_backend_label_litert"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tai_catalog_filter_mnn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/termux_ai_backend_label_mnn"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tai_catalog_filter_installed"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/termux_ai_catalog_filter_installed"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tai_catalog_filter_usable"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/termux_ai_catalog_filter_usable"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
