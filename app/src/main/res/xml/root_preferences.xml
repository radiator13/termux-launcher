<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="root_assistant"
        app:title="@string/settings_root_assistant_header">

        <Preference
            app:key="termux_ai"
            app:icon="@drawable/ic_settings_ai"
            app:title="@string/termux_ai_preferences_title"
            app:summary="@string/termux_ai_preferences_summary"
            app:fragment="com.termux.app.fragments.settings.termux.TaiPreferencesFragment"/>

        <com.termux.app.fragments.settings.PillPreference
            app:key="shizuku"
            app:icon="@drawable/ic_settings_shield"
            app:title="@string/termux_privileged_access_preferences_title"
            app:summary="@string/termux_privileged_access_preferences_summary"
            app:fragment="com.termux.app.fragments.settings.termux.PrivilegedAccessPreferencesFragment"/>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="root_launcher"
        app:title="@string/settings_root_launcher_header">

        <Preference
            app:key="termux"
            app:icon="@drawable/ic_settings_terminal"
            app:title="@string/termux_preferences_title"
            app:summary="@string/termux_preferences_summary"
            app:fragment="com.termux.app.fragments.settings.TermuxPreferencesFragment"/>

        <Preference
            app:key="look_and_feel"
            app:icon="@drawable/ic_settings_palette"
            app:title="@string/termux_style_preferences_title"
            app:summary="@string/termux_style_preferences_summary"
            app:fragment="com.termux.app.fragments.settings.termux.TermuxStylePreferencesFragment"/>

        <Preference
            app:key="apps_bar"
            app:icon="@drawable/ic_settings_grid"
            app:title="@string/termux_launcher_preferences_title"
            app:summary="@string/termux_launcher_preferences_summary"
            app:fragment="com.termux.app.fragments.settings.termux.LauncherPreferencesFragment"/>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="root_system_info"
        app:title="@string/settings_root_system_info_header">

        <Preference
            app:key="termux_api"
            app:icon="@drawable/ic_settings_plug"
            app:title="@string/termux_api_preferences_title"
            app:summary="@string/termux_api_preferences_summary"
            app:isPreferenceVisible="false"
            app:fragment="com.termux.app.fragments.settings.TermuxAPIPreferencesFragment"/>

        <Preference
            app:key="termux_float"
            app:title="@string/termux_float_preferences_title"
            app:summary="@string/termux_float_preferences_summary"
            app:isPreferenceVisible="false"
            app:fragment="com.termux.app.fragments.settings.TermuxFloatPreferencesFragment"/>

        <Preference
            app:key="termux_tasker"
            app:title="@string/termux_tasker_preferences_title"
            app:summary="@string/termux_tasker_preferences_summary"
            app:isPreferenceVisible="false"
            app:fragment="com.termux.app.fragments.settings.TermuxTaskerPreferencesFragment"/>

        <Preference
            app:key="termux_gui"
            app:title="@string/termux_gui_preferences_title"
            app:summary="@string/termux_gui_preferences_summary"
            app:isPreferenceVisible="false"
            app:fragment="com.termux.app.fragments.settings.TermuxGUIPreferencesFragment"/>

        <Preference
            app:key="termux_widget"
            app:title="@string/termux_widget_preferences_title"
            app:summary="@string/termux_widget_preferences_summary"
            app:isPreferenceVisible="false"
            app:fragment="com.termux.app.fragments.settings.TermuxWidgetPreferencesFragment"/>

        <Preference
            app:key="about"
            app:icon="@drawable/ic_settings_info"
            app:title="@string/about_preference_title"
            app:summary="@string/about_preference_summary"
            app:persistent="false"/>

        <Preference
            app:key="open_source_licenses"
            app:icon="@drawable/ic_settings_info"
            app:title="@string/open_source_licenses_preference_title"
            app:summary="@string/open_source_licenses_preference_summary"
            app:persistent="false"/>

        <Preference
            app:key="donate"
            app:icon="@drawable/ic_settings_heart"
            app:title="@string/donate_preference_title"
            app:summary="@string/donate_preference_summary"
            app:persistent="false"
            app:isPreferenceVisible="false"/>

    </PreferenceCategory>

</PreferenceScreen>
