<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="apps_bar_primary"
        app:title="@string/apps_bar_behavior_header">

        <SwitchPreferenceCompat
            app:key="app_launcher_apps_row_enabled"
            app:title="@string/termux_app_launcher_apps_row_enabled_title"
            app:summary="@string/termux_app_launcher_apps_row_enabled_summary"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="app_launcher_az_row_enabled"
            app:title="@string/termux_app_launcher_az_row_enabled_title"
            app:summary="@string/termux_app_launcher_az_row_enabled_summary"
            app:dependency="app_launcher_apps_row_enabled"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="app_launcher_notification_dots"
            app:title="@string/termux_app_launcher_notification_dots_title"
            app:summary="@string/termux_app_launcher_notification_dots_summary"
            app:dependency="app_launcher_apps_row_enabled"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="app_launcher_most_used_page"
            app:title="@string/termux_app_launcher_most_used_page_title"
            app:summary="@string/termux_app_launcher_most_used_page_summary"
            app:dependency="app_launcher_apps_row_enabled"
            android:defaultValue="false" />

        <ListPreference
            app:key="app_launcher_az_lock_method"
            app:title="@string/termux_app_launcher_az_double_tap_lock_title"
            app:summary="@string/termux_app_launcher_az_double_tap_lock_summary"
            app:dialogTitle="@string/termux_app_launcher_az_lock_method_dialog_title"
            android:defaultValue="off"
            app:entries="@array/app_launcher_az_lock_method_entries"
            app:entryValues="@array/app_launcher_az_lock_method_values" />

        <Preference
            app:key="app_launcher_set_home"
            app:title="@string/termux_app_launcher_set_home_title"
            app:summary="@string/termux_app_launcher_set_home_summary" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="apps_bar_search"
        app:title="@string/apps_bar_search_header">

        <EditTextPreference
            app:key="app_launcher_input_char"
            app:title="@string/termux_app_launcher_input_char_title"
            app:summary="@string/termux_app_launcher_input_char_summary"
            android:defaultValue="%"
            android:inputType="text" />

        <Preference
            app:key="app_launcher_reset_usage_ranking"
            app:title="@string/termux_app_launcher_reset_usage_ranking_title"
            app:summary="@string/termux_app_launcher_reset_usage_ranking_summary" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="apps_bar_maintenance"
        app:title="@string/apps_bar_maintenance_header">

        <Preference
            app:key="app_launcher_default_buttons"
            app:title="@string/termux_app_launcher_default_buttons_title"
            app:summary="@string/termux_app_launcher_default_buttons_summary" />
    </PreferenceCategory>

    <PreferenceCategory
        app:key="apps_bar_permissions"
        app:title="@string/apps_bar_permissions_header">

        <com.termux.app.fragments.settings.PillPreference
            app:key="app_launcher_storage_access"
            app:title="@string/termux_app_launcher_storage_access_title" />

        <com.termux.app.fragments.settings.PillPreference
            app:key="app_launcher_notification_access"
            app:title="@string/termux_app_launcher_notification_access_settings_title" />

        <com.termux.app.fragments.settings.PillPreference
            app:key="app_launcher_accessibility_lock_access"
            app:title="@string/termux_app_launcher_accessibility_lock_access_title" />

        <com.termux.app.fragments.settings.PillPreference
            app:key="app_launcher_notification_settings"
            app:title="@string/termux_app_launcher_notification_settings_title" />

        <Preference
            app:key="app_launcher_app_permissions"
            app:title="@string/termux_app_launcher_app_permissions_title"
            app:summary="@string/termux_app_launcher_app_permissions_summary" />

    </PreferenceCategory>

</PreferenceScreen>
