<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="tai_catalog_controls_category"
        app:title="@string/termux_ai_catalog_controls_title">
        <ListPreference
            app:key="tai_catalog_backend_filter"
            app:title="@string/termux_ai_catalog_backend_filter_title"
            app:entries="@array/termux_ai_catalog_backend_filter_entries"
            app:entryValues="@array/termux_ai_catalog_backend_filter_values"
            app:defaultValue="all"
            app:persistent="false" />
        <EditTextPreference
            app:key="tai_catalog_search"
            app:title="@string/termux_ai_catalog_search_title"
            app:dialogTitle="@string/termux_ai_catalog_search_title"
            app:useSimpleSummaryProvider="true"
            app:persistent="false" />
        <Preference
            app:key="tai_catalog_import"
            app:title="@string/termux_ai_model_import_title"
            app:summary="@string/termux_ai_model_import_summary"
            app:persistent="false" />
    </PreferenceCategory>

    <PreferenceCategory
        app:key="tai_catalog_results_category"
        app:title="@string/termux_ai_catalog_results_title" />
</PreferenceScreen>
