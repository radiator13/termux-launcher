<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="ThemeOverlay.TermuxPalette" parent="" />

    <style name="ThemeOverlay.TermuxPalette.Default" parent="ThemeOverlay.TermuxPalette">
        <item name="termuxColorSurfaceBase">@color/theme_default_surface_base</item>
        <item name="termuxColorSurfacePanel">@color/theme_default_surface_panel</item>
        <item name="termuxColorSurfacePanelHigh">@color/theme_default_surface_panel_high</item>
        <item name="termuxColorSurfacePanelHighest">@color/theme_default_surface_panel_highest</item>
        <item name="termuxColorOnSurface">@color/theme_default_on_surface</item>
        <item name="termuxColorOnSurfaceVariant">@color/theme_default_on_surface_variant</item>
        <item name="termuxColorOutlineVariant">@color/theme_default_outline_variant</item>
        <item name="termuxColorAccentContainer">@color/theme_default_accent_container</item>
        <item name="termuxColorOnAccentContainer">@color/theme_default_on_accent_container</item>
    </style>

    <style name="TermuxAlertDialogStyle" parent="@android:style/Theme.Material.Light.Dialog.Alert" />

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Light" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">?attr/termuxColorOnSurfaceVariant</item>
    </style>

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Dark" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">?attr/termuxColorOnSurface</item>
    </style>

</resources>
