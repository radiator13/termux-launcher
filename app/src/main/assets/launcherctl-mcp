#!/data/data/com.termux/files/usr/bin/python3
"""MCP stdio bridge for LauncherCtl tools.

The bridge exposes the local LauncherCtl agent tools over JSON-RPC so MCP
clients can list and call Android launcher actions without knowing the
LauncherCtl HTTP API details. It intentionally uses only Python's standard
library to keep it usable on a fresh Termux install with `pkg install python`.
"""

import json
import os
import sys
import urllib.error
import urllib.request


PROTOCOL_VERSION = "2025-06-18"
SERVER_NAME = "termux-launcherctl"
SERVER_VERSION = "0.1.0"


class JsonRpcTransport:
    def __init__(self):
        self.reader = sys.stdin.buffer
        self.writer = sys.stdout.buffer
        self.content_length_mode = None

    def read_message(self):
        while True:
            line = self.reader.readline()
            if line == b"":
                return None
            if line.startswith(b"Content-Length:") or line.startswith(b"content-length:"):
                self.content_length_mode = True
                headers = {}
                while line and line.strip():
                    text = line.decode("ascii", "replace").strip()
                    if ":" in text:
                        key, value = text.split(":", 1)
                        headers[key.strip().lower()] = value.strip()
                    line = self.reader.readline()
                length = int(headers.get("content-length", "0"))
                if length <= 0:
                    raise ValueError("Invalid Content-Length")
                body = self.reader.read(length)
                if len(body) != length:
                    raise EOFError("Unexpected EOF while reading message body")
                return json.loads(body.decode("utf-8"))
            stripped = line.strip()
            if not stripped:
                continue
            if self.content_length_mode is None:
                self.content_length_mode = False
            return json.loads(stripped.decode("utf-8"))

    def write_message(self, message):
        body = json.dumps(message, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
        if self.content_length_mode:
            header = ("Content-Length: %d\r\n\r\n" % len(body)).encode("ascii")
            self.writer.write(header)
            self.writer.write(body)
        else:
            self.writer.write(body)
            self.writer.write(b"\n")
        self.writer.flush()


class LauncherCtlClient:
    def __init__(self):
        home = os.path.expanduser("~")
        self.config_dir = os.path.join(home, ".launcherctl")
        self.endpoint_file = os.path.join(self.config_dir, "endpoint")
        self.token_file = os.path.join(self.config_dir, "token")

    def _read_first_line(self, path):
        with open(path, "r", encoding="utf-8") as handle:
            for line in handle:
                value = line.strip()
                if value:
                    return value
        return ""

    def _config(self):
        if not os.path.exists(self.endpoint_file) or not os.path.exists(self.token_file):
            raise RuntimeError("LauncherCtl is not configured; start Termux Launcher first")
        base_url = self._read_first_line(self.endpoint_file).rstrip("/")
        token = self._read_first_line(self.token_file)
        if not base_url or not token:
            raise RuntimeError("LauncherCtl endpoint or token is empty")
        return base_url, token

    def request(self, method, path, payload=None):
        base_url, token = self._config()
        data = None
        headers = {
            "Authorization": "Bearer " + token,
            "Accept": "application/json",
        }
        if payload is not None:
            data = json.dumps(payload, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
            headers["Content-Type"] = "application/json"
        request = urllib.request.Request(base_url + path, data=data, headers=headers, method=method)
        try:
            with urllib.request.urlopen(request, timeout=60) as response:
                body = response.read().decode("utf-8")
                return json.loads(body) if body else {}
        except urllib.error.HTTPError as error:
            body = error.read().decode("utf-8", "replace")
            try:
                data = json.loads(body) if body else {}
            except json.JSONDecodeError:
                data = {"ok": False, "error": "http_error", "message": body}
            data.setdefault("ok", False)
            data.setdefault("status", error.code)
            raise LauncherCtlHttpError(data)
        except urllib.error.URLError as error:
            raise RuntimeError("LauncherCtl API is not reachable: %s" % error.reason)

    def get_tools(self):
        return self.request("GET", "/v1/agent/tools")

    def execute_tool(self, name, arguments):
        args = dict(arguments or {})
        confirm = bool(args.pop("_confirm", False))
        payload = {
            "tool": name,
            "arguments": args,
            "confirm": confirm,
        }
        return self.request("POST", "/v1/agent/execute", payload)


class LauncherCtlHttpError(Exception):
    def __init__(self, payload):
        super().__init__(payload.get("message") or payload.get("error") or "LauncherCtl HTTP error")
        self.payload = payload


class McpBridge:
    def __init__(self):
        self.client = LauncherCtlClient()

    def handle_message(self, message):
        if isinstance(message, list):
            responses = []
            for item in message:
                response = self.handle_message(item)
                if response is not None:
                    responses.append(response)
            return responses or None
        if not isinstance(message, dict):
            return self.error(None, -32600, "Invalid Request")

        request_id = message.get("id")
        method = message.get("method")
        params = message.get("params") or {}
        if not method:
            return self.error(request_id, -32600, "Invalid Request")

        is_notification = "id" not in message
        try:
            result = self.dispatch(method, params)
        except LauncherCtlHttpError as error:
            if is_notification:
                return None
            return self.error(request_id, -32000, "LauncherCtl API error", error.payload)
        except MethodNotFound as error:
            if is_notification:
                return None
            return self.error(request_id, -32601, "Method not found: %s" % error)
        except InvalidParams as error:
            if is_notification:
                return None
            return self.error(request_id, -32602, str(error))
        except Exception as error:
            if is_notification:
                print("launcherctl-mcp: %s" % error, file=sys.stderr)
                return None
            return self.error(request_id, -32603, str(error))

        if is_notification:
            return None
        return {
            "jsonrpc": "2.0",
            "id": request_id,
            "result": result,
        }

    def dispatch(self, method, params):
        if method == "initialize":
            requested = params.get("protocolVersion") if isinstance(params, dict) else None
            version = requested or PROTOCOL_VERSION
            return {
                "protocolVersion": version,
                "capabilities": {
                    "tools": {},
                },
                "serverInfo": {
                    "name": SERVER_NAME,
                    "version": SERVER_VERSION,
                },
            }
        if method == "ping":
            return {}
        if method == "notifications/initialized":
            return {}
        if method == "tools/list":
            return self.tools_list()
        if method == "tools/call":
            return self.tools_call(params)
        if method == "resources/list":
            return {"resources": []}
        if method == "prompts/list":
            return {"prompts": []}
        if method == "logging/setLevel":
            return {}
        raise MethodNotFound(method)

    def tools_list(self):
        payload = self.client.get_tools()
        tools_by_openai_name = {}
        for tool in payload.get("tools", []):
            tools_by_openai_name[tool.get("openAiName") or tool.get("name")] = tool

        tools = []
        for item in payload.get("openAiTools", []):
            function = item.get("function", {})
            name = function.get("name")
            if not name:
                continue
            metadata = tools_by_openai_name.get(name, {})
            risk = metadata.get("risk", "low")
            requires_confirmation = bool(metadata.get("requiresConfirmation", False))
            tools.append({
                "name": name,
                "description": function.get("description", ""),
                "inputSchema": function.get("parameters", {"type": "object", "properties": {}}),
                "annotations": {
                    "readOnlyHint": risk == "low" and not requires_confirmation,
                    "destructiveHint": risk in ("high", "critical"),
                    "openWorldHint": name in ("apps_launch", "intent_open"),
                },
            })
        return {"tools": tools}

    def tools_call(self, params):
        if not isinstance(params, dict):
            raise InvalidParams("tools/call params must be an object")
        name = params.get("name")
        if not name:
            raise InvalidParams("tools/call requires a tool name")
        arguments = params.get("arguments") or {}
        if not isinstance(arguments, dict):
            raise InvalidParams("tools/call arguments must be an object")
        result = self.client.execute_tool(name, arguments)
        ok = bool(result.get("ok", False))
        text = json.dumps(result, ensure_ascii=False, indent=2)
        return {
            "content": [
                {
                    "type": "text",
                    "text": text,
                },
            ],
            "isError": not ok,
        }

    def error(self, request_id, code, message, data=None):
        error = {
            "code": code,
            "message": message,
        }
        if data is not None:
            error["data"] = data
        return {
            "jsonrpc": "2.0",
            "id": request_id,
            "error": error,
        }


class MethodNotFound(Exception):
    pass


class InvalidParams(Exception):
    pass


def main():
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help", "help"):
        print("Usage: launcherctl-mcp")
        print("Runs an MCP stdio server backed by the local LauncherCtl API.")
        return 0

    transport = JsonRpcTransport()
    bridge = McpBridge()
    while True:
        try:
            message = transport.read_message()
        except json.JSONDecodeError as error:
            transport.write_message(bridge.error(None, -32700, "Parse error: %s" % error))
            continue
        except Exception as error:
            print("launcherctl-mcp: %s" % error, file=sys.stderr)
            return 1
        if message is None:
            return 0

        response = bridge.handle_message(message)
        if response is not None:
            transport.write_message(response)


if __name__ == "__main__":
    sys.exit(main())
